# Discord Bot Configuration
# Token do bot (encontre em: Discord Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=seu_token_aqui

# Application ID do bot (encontre em: Discord Developer Portal > General Information > Application ID)
# NÃO é o ID do owner, é o ID da aplicação/bot
CLIENT_ID=seu_client_id_aqui

# ID do servidor (opcional - use apenas para desenvolvimento rápido)
# Se definido, os comandos serão registrados apenas neste servidor
# Se não definido, os comandos serão registrados globalmente
GUILD_ID=seu_guild_id_aqui_opcional

# Environment
NODE_ENV=development
