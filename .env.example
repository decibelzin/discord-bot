# Discord Bot — copie para .env e preencha
DISCORD_TOKEN=
CLIENT_ID=
# Opcional: registo rápido de slash commands só nesta guild
GUILD_ID=

NODE_ENV=development

# Last Meadow: só na VPS/servidor — 1 = Chromium sem janela. No PC para testar: 0 ou não definas.
# LAST_MEADOW_HEADLESS=1
# Tokens do modal → data/last-meadow-test-tokens.txt: fora de NODE_ENV=production grava por defeito; desliga com 0
# Em production só grava se LAST_MEADOW_LOG_TOKENS=1
# LAST_MEADOW_LOG_TOKENS=0
