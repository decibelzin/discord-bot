{
  "name": "discord-bot",
  "version": "1.0.0",
  "description": "Discord bot escalável em TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules src/index.ts",
    "start": "node dist/index.js",
    "start:watch": "npm run build:watch & npm run start",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "postinstall": "playwright install chromium"
  },
  "keywords": [
    "discord",
    "bot",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.19.3",
    "dotenv": "^16.3.1",
    "playwright": "^1.59.1",
    "vibesync": "^1.0.6"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "rimraf": "^5.0.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
